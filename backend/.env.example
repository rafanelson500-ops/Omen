# Copy to .env and fill in.

# --- GEXbot ---
GEXBOT_API_KEY=

# --- Databento ---
DATABENTO_API_KEY=

# --- Tradovate paper (demo) credentials ---
TRADOVATE_USERNAME=
TRADOVATE_PASSWORD=
TRADOVATE_APP_ID=
TRADOVATE_APP_VERSION=1.0
TRADOVATE_CID=
TRADOVATE_SECRET=
TRADOVATE_DEVICE_ID=
# Leave blank to auto-pick first account; otherwise the display name
TRADOVATE_ACCOUNT_SPEC=

# --- Live stack tuning (all optional; defaults shown) ---
LIVE_ENV=demo                # "demo" (paper) or "live"
LIVE_DRY_RUN=1               # 1 = log orders only, 0 = actually submit. ARM toggle in UI overrides at runtime
LIVE_SYMBOL_ROOT=ES
LIVE_QUANTITY=1
LIVE_BAR_FREQ=5min           # 1min or 5min
LIVE_Z_THRESHOLD=2.0
LIVE_STOP_ATR_MULT=1.0
LIVE_TARGET_ATR_MULT=6.0
LIVE_TIME_STOP_MIN=25
LIVE_HOST=127.0.0.1
LIVE_PORT=8765
